{
  "name": "mmm-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace/mmm",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/mmm,type=bind",
  "remoteUser": "vscode",
  "postCreateCommand": "python -m pip install -U pip && pip install -e \".[dev,tracking]\"",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
